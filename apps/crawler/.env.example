# Google Gemini (LangChain)
GOOGLE_API_KEY=your-google-api-key

# Chanban API
CHANBAN_API_URL=http://localhost:3001/api

# 정치 성향형 페르소나 (기존)
CHANBAN_JWT_MINJU_TOKEN=your-jwt-token
CHANBAN_JWT_GUKHIM_TOKEN=your-jwt-token
CHANBAN_JWT_JUNGDO_TOKEN=your-jwt-token
CHANBAN_JWT_MZ_TOKEN=your-jwt-token
CHANBAN_JWT_ELDER_TOKEN=your-jwt-token

# 생활·직군형 페르소나 (신규) — make setup-bots 실행 시 자동 채워짐
CHANBAN_JWT_WORKINGMOM_TOKEN=your-jwt-token
CHANBAN_JWT_SELFEMPLOYED_TOKEN=your-jwt-token
CHANBAN_JWT_JOBSEEKER_TOKEN=your-jwt-token
CHANBAN_JWT_OFFICE_TOKEN=your-jwt-token
CHANBAN_JWT_DOCTOR_TOKEN=your-jwt-token
CHANBAN_JWT_TEACHER_TOKEN=your-jwt-token
CHANBAN_JWT_FARMER_TOKEN=your-jwt-token
CHANBAN_JWT_INVESTOR_TOKEN=your-jwt-token
CHANBAN_JWT_STUDENT_TOKEN=your-jwt-token
CHANBAN_JWT_RETIREE_TOKEN=your-jwt-token
